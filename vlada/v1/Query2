[
  {
    $sort: { modified_date: 1 }
  },
  {
    $group: {
      _id: "$gtin_upc",
      owner: { $last: "$owner" },
      "Vitamin A, IU-IU": {
        $last: "$Vitamin A, IU-IU"
      },
      "Vitamin B-6-MG": {
        $last: "$Vitamin B-6-MG"
      },
      "Vitamin B-12-UG": {
        $last: "$Vitamin B-12-UG"
      },
      "Vitamin C, total ascorbic acid-MG": {
        $last:
          "$Vitamin C, total ascorbic acid-MG"
      },
      "Vitamin D (D2 + D3), International Units-IU":
        {
          $last:
            "$Vitamin D (D2 + D3), International Units-IU"
        }
    }
  },
  {
    $lookup: {
      from: "owners",
      localField: "owner",
      foreignField: "_id",
      as: "owners"
    }
  },
  { $unwind: "$owners" },
  {
    $group: {
      _id: "$owner",
      name: { $last: "$owners.name" },
      vitamin_a_mean: {
        $avg: "$Vitamin A, IU-IU"
      },
      vitamin_a_std: {
        $stdDevPop: "$Vitamin A, IU-IU"
      },
      vitamin_a_max: {
        $max: "$Vitamin A, IU-IU"
      },
      vitamin_a_min: {
        $min: "$Vitamin A, IU-IU"
      },
      vitamin_b6_mean: {
        $avg: "$Vitamin B-6-MG"
      },
      vitamin_b6_std: {
        $stdDevPop: "$Vitamin B-6-MG"
      },
      vitamin_b6_max: {
        $max: "$Vitamin B-6-MG"
      },
      vitamin_b6_min: {
        $min: "$Vitamin B-6-MG"
      },
      vitamin_b12_mean: {
        $avg: "$Vitamin B-12-UG"
      },
      vitamin_b12_std: {
        $stdDevPop: "$Vitamin B-12-UG"
      },
      vitamin_b12_max: {
        $max: "$Vitamin B-12-UG"
      },
      vitamin_b12_min: {
        $min: "$Vitamin B-12-UG"
      },
      vitamin_c_mean: {
        $avg: "$Vitamin C, total ascorbic acid-MG"
      },
      vitamin_c_std: {
        $stdDevPop:
          "$Vitamin C, total ascorbic acid-MG"
      },
      vitamin_c_max: {
        $max: "$Vitamin C, total ascorbic acid-MG"
      },
      vitamin_c_min: {
        $min: "$Vitamin C, total ascorbic acid-MG"
      },
      vitamin_d_mean: {
        $avg: "$Vitamin D (D2 + D3), International Units-IU"
      },
      vitamin_d_std: {
        $stdDevPop:
          "$Vitamin D (D2 + D3), International Units-IU"
      },
      vitamin_d_max: {
        $max: "$Vitamin D (D2 + D3), International Units-IU"
      },
      vitamin_d_min: {
        $min: "$Vitamin D (D2 + D3), International Units-IU"
      }
    }
  },
  {
    $project: {
      owner: "$name",
      vitamin_a_mean: 1,
      vitamin_a_std: 1,
      vitamin_a_max: 1,
      vitamin_a_min: 1,
      vitamin_b6_mean: 1,
      vitamin_b6_std: 1,
      vitamin_b6_max: 1,
      vitamin_b6_min: 1,
      vitamin_b12_mean: 1,
      vitamin_b12_std: 1,
      vitamin_b12_max: 1,
      vitamin_b12_min: 1,
      vitamin_c_mean: 1,
      vitamin_c_std: 1,
      vitamin_c_max: 1,
      vitamin_c_min: 1,
      vitamin_d_mean: 1,
      vitamin_d_std: 1,
      vitamin_d_max: 1,
      vitamin_d_min: 1
    }
  },
  {
    $sort: {
      owner: 1
    }
  },
  {
    $match: {
      vitamin_a_mean: { $ne: 0 },
      vitamin_a_std: { $ne: 0 },
      vitamin_a_max: { $ne: 0 },
      vitamin_a_min: { $ne: 0 },
      vitamin_b6_mean: { $ne: 0 },
      vitamin_b6_std: { $ne: 0 },
      vitamin_b6_max: { $ne: 0 },
      vitamin_b6_min: { $ne: 0 },
      vitamin_b12_mean: { $ne: 0 },
      vitamin_b12_std: { $ne: 0 },
      vitamin_b12_max: { $ne: 0 },
      vitamin_b12_min: { $ne: 0 },
      vitamin_c_mean: { $ne: 0 },
      vitamin_c_std: { $ne: 0 },
      vitamin_c_max: { $ne: 0 },
      vitamin_c_min: { $ne: 0 },
      vitamin_d_mean: { $ne: 0 },
      vitamin_d_std: { $ne: 0 },
      vitamin_d_max: { $ne: 0 },
      vitamin_d_min: { $ne: 0 }
    }
  }
]